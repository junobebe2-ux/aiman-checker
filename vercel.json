{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" },
    { "src": "**/*.css", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/check", "dest": "/api/check.js" },
    { "src": "/api/guestpost", "dest": "/api/guestpost.js" },
    { "src": "/api/test", "dest": "/api/test.js" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}