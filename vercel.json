{
  "version": 3,
  "rewrites": [
    { "source": "/api/check", "destination": "/api/check.js" },
    { "source": "/api/guestpost", "destination": "/api/guestpost.js" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ],
  "functions": {
    "api/**/*.js": {
      "runtime": "nodejs20.x"
    }
  },
  "env": {
    "EC2_SCRAPER": "https://exemption-portrait-badge-encounter.trycloudflare.com"
  }
}